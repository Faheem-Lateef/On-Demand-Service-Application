PORT=3000

# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/on_demand_service"

# Generate a strong 64-byte random hex string for your JWT secret
JWT_SECRET="replace_with_a_secure_random_string_for_production"

# REQUIRED: A DIFFERENT secret used to sign refresh tokens (7-day TTL)
# Must not be the same as JWT_SECRET
JWT_REFRESH_SECRET="replace_with_a_different_secure_random_string_for_production"

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:8081"
